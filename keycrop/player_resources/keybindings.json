// Place your key bindings in this file to override the defaults
[
    {
        "key": "ctrl+c",
        "command": "runCommands",
        "args": {
            "commands": [
                "editor.action.clipboardCopyAction",
                "keycrop.growChili"
            ]
        }
    },
    {
        "key": "ctrl+v",
        "command": "runCommands",
        "args": {
            "commands": [
                "editor.action.clipboardPasteAction",
                "keycrop.growBean"
            ]
        }
    },
    {
        "key": "ctrl+p",
        "command": "runCommands",
        "args": {
            "commands": [
                "workbench.action.quickOpen",
                "keycrop.growTomato"
            ]
        }
    },
    {
        "key": "ctrl+a",
        "command": "runCommands",
        "args": {
            "commands": [
                "editor.action.selectAll",
                "keycrop.growLettuce"
            ]
        }
    },
    {
        "key": "ctrl+x",
        "command": "runCommands",
        "args": {
            "commands": [
                "editor.action.clipboardCutAction" ,
                "keycrop.growBroccoli"
            ]
        }
    }
]